<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:strings="clr-namespace:CityExplorer.Resources.Strings"
             x:Class="CityExplorer.Views.SettingsPage"
             BackgroundColor="#0B1220"
             Title="{Binding [SettingsTitle], Source={x:Static strings:LocalizationResourceManager.Instance}}">

    <VerticalStackLayout Padding="20" Spacing="20">

        <Label Text="{Binding [SettingsTitle], Source={x:Static strings:LocalizationResourceManager.Instance}}"
               FontSize="26"
               FontAttributes="Bold"
               TextColor="White"
               HorizontalOptions="Center"/>

        <Frame BackgroundColor="#111827"
               CornerRadius="18"
               Padding="16"
               HasShadow="True">

            <VerticalStackLayout Spacing="12">

                <Label Text="{Binding [SelectLanguage], Source={x:Static strings:LocalizationResourceManager.Instance}}"
                       FontSize="16"
                       TextColor="#9CA3AF"/>

                <Picker ItemsSource="{Binding Languages}"
                        SelectedItem="{Binding SelectedLanguage}"
                        Title="{Binding [SelectLanguage], Source={x:Static strings:LocalizationResourceManager.Instance}}"
                        TextColor="White"
                        BackgroundColor="#1F2937"/>

            </VerticalStackLayout>

        </Frame>

    </VerticalStackLayout>

</ContentPage>